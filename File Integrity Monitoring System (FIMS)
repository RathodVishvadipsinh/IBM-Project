# ---------------- MONITOR ----------------
class MonitorHandler(FileSystemEventHandler):
    def __init__(self):
        self.hashes = {}

    def on_modified(self, event):
        if not event.is_directory:
            path = event.src_path
            new_hash = generate_hash(path)

            if path in self.hashes:
                if self.hashes[path] != new_hash:
                    print(" Modified:", path)
                    send_email_alert(path)

            self.hashes[path] = new_hash

def start_monitor(folder):
    observer = Observer()
    handler = MonitorHandler()
    observer.schedule(handler, folder, recursive=True)
    observer.start()

    print(" Monitoring Started...")

    try:
        while True:
            time.sleep(1)
    except:
        observer.stop()

    observer.join()

# ---------------- APP ----------------
class App:
    def __init__(self, root):
        self.root = root
        self.root.title("Cyber Security Tool 🛡️")
        self.root.geometry("1000x650")
        self.root.configure(bg="#1a102c")

        # NAVBAR
        navbar = tk.Frame(root, bg="#1a102c", height=70)
        navbar.pack(fill="x")

        tk.Label(navbar, text="🛡️ Cyber Security Tool",
                 bg="#1a102c", fg="#c084fc",
                 font=("Segoe UI", 16, "bold")).pack(side="left", padx=20)

        def nav_btn(text, cmd):
            return tk.Button(navbar, text=text, command=cmd,
                             bg="#1a102c", fg="#c084fc",
                             bd=0, font=("Segoe UI", 12, "bold"),
                             cursor="hand2")

        nav_btn("🏠 Home", self.show_home).pack(side="right", padx=20)
        nav_btn("📄 About", self.show_about).pack(side="right", padx=20)
        nav_btn("🔐 Why Important", self.show_why).pack(side="right", padx=20)

        # CONTAINER
        self.container = tk.Frame(root, bg="#1a102c")
        self.container.pack(expand=True, fill="both")

        self.frames = {}

        for F in (HomePage, AboutPage, WhyPage):
            frame = F(self.container, self)
            self.frames[F] = frame
            frame.place(relwidth=1, relheight=1)

        self.show_home()

    def show_home(self):
        self.frames[HomePage].tkraise()

    def show_about(self):
        self.frames[AboutPage].tkraise()

    def show_why(self):
        self.frames[WhyPage].tkraise()

# ---------------- CARD ----------------
def create_card(parent):
    frame = tk.Frame(parent, bg="#2a1b47")
    frame.config(highlightbackground="#c084fc", highlightthickness=2)
    return frame

